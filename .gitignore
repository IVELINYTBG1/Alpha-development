# ── Rust build artifacts ─────────────────────────────────────────────
/target/
**/*.rs.bk

# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
.venv*/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/

# ── Runtime / generated ──────────────────────────────────────────────
brain_log.txt
brain_stderr.log
crash.log
*.log

# ── Per-run learned / PERSONAL state — never committed ───────────────
# semantic_memory.json now also holds the architect's biometric identity
# (face + voice templates), so it must stay LOCAL/private. It regenerates its
# Alpha seed lexicon on first run, so nothing is lost by not shipping it.
semantic_memory.json
training_trace.jsonl
*.npz
babble_*.json
working_memory_*.json
voice_esteem_*.json
reason_links.json
syntax_*.json
conversation_log.jsonl
voice_identity.json
imprinter_state.json

# ── Environment ──────────────────────────────────────────────────────
.env
.env.local

# ── OS / editor cruft ────────────────────────────────────────────────
.DS_Store
*.swp
*.swo
.idea/
.vscode/
.claude/

# ── Models (downloaded on demand) ────────────────────────────────────
*.bin
*.pt
*.pth
*.onnx
*.onnx.json
models/
.cache/
voices/piper/

# ── Large external files / media ─────────────────────────────────────
MediCat*/
ventoy/
*.torrent
